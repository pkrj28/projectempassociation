{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.pjnamespace.project4",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.21.0",
      "toolsId": "14a25944-c68e-4c6b-999b-84069c649f34"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZEMPDATA_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.pjnamespace.project4.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      },
      "empModel":{
           "type": "sap.ui.model.json.JSONModel"
      },
      "projModel":{
      "type": "sap.ui.model.json.JSONModel"

      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.pjnamespace.project4.view",
        "async": true,
        "viewPath": "com.pjnamespace.project4.view"
      },
      "routes": [
        {
          "name": "RouteView1",
          "pattern": "",
          "target": [
            "TargetView1"
          ]
        },
        {
          "name": "RouteView2",
          "pattern": "second/{key}",
          "target": [
            "TargetView2"
          ]
        },
        {
          "name": "RouteView3",
          "pattern": "thirdview",
          "target": [
            "TargetView3"
          ]
        },
        {
          "name": "RouteView4",
          "pattern": "fourthview/{key}",
          "target": [
            "TargetView4"
          ]
        },
        {
          "name": "RouteView7",
          "pattern": "seventhview",
          "target": [
            "TargetView7"
          ]
        }
      ],
      "targets": {
        "TargetView1": {
          "id": "View1",
          "name": "View1"
        },
        "TargetView2": {
          "id": "View2",
          "name": "View2"
        },
         "TargetView3": {
          "id": "View3",
          "name": "View3"
        },
         "TargetView4": {
          "id": "View4",
          "name": "View4"
        },
        "TargetView7": {
          "id": "View7",
          "name": "View7"
        }
      }
    },
    "rootView": {
      "viewName": "com.pjnamespace.project4.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
