<mvc:View xmlns:unified="sap.ui.unified"
	xmlns:richtexteditor="sap.fe.macros.richtexteditor"
	xmlns:core="sap.ui.core" controllerName="com.pjnamespace.project4.controller.View3"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:upload="sap.m.upload"
	>
	<Page id="page3" title="Create Employee View3" showNavButton="true" navButtonPress="onBack">
		<content>
 <f:SimpleForm title="Enter Employee Details" editable="true" layout="ResponsiveGridLayout" labelSpanL="2" emptySpanL="6" 
																											emptySpanM="6">
				<f:content>
				<Label text="Employee ID"></Label>
				<Input id="Empid"></Input>

				<Label text="Employee Name"></Label>
				<Input id="Empname"></Input>

                <Label text="City"></Label>
				<Input id="City"></Input>

				<Label text="Country"></Label>
				<Input id="Country"></Input>

                <Label text="Salary"></Label>
				<Input id="Salary"></Input>

				<Label text="Currency"></Label>
				<Input id="Currency"></Input>

                <Label text="Status"></Label>
				<Input id="Status"></Input>

				<Label text="Begin Date"></Label>
                <DatePicker id="Begindate"></DatePicker>
	

                <Label text="Phone number"></Label>
				<Input id="Phonenumber"></Input>

				<Label text="Email ID"></Label>
				<Input id="Mailid"></Input>
                	
			<FlexBox justifyContent="End">
					
			</FlexBox>
			</f:content>
			</f:SimpleForm>
		<Table items="{projModel>/aProjects}" >
		<headerToolbar>
		<Toolbar  >
		<Title text="Add Project"></Title>
		<ToolbarSpacer ></ToolbarSpacer>
		<Button text="Add" icon="sap-icon://add" type="Emphasized" press="Onadd"> </Button>
		</Toolbar>
		</headerToolbar>
		<columns>
		<Column >
		<Text text="Employee ID "></Text>	
		</Column>
		<Column >
		<Text text="Project ID "></Text>	
		</Column>
		<Column >
		<Text text="Project Name "></Text>	
		</Column>
		<Column >
		<Text text="Project Descrip "></Text>	
		</Column>
		<Column >
		<Text text="Client Name "></Text>	
		</Column>
		<Column >
		<Text text="Delete "></Text>	
		</Column>
		</columns>
		<items>
		<ColumnListItem  >
		<Input value="{projModel>Empid}"></Input>
		<Input value="{projModel>Projid}"></Input>
		<Input value="{projModel>Projname}"></Input>
		<Input value="{projModel>Projdes}"></Input>
		<Input value="{projModel>Clientname}"></Input>
		<Button icon="sap-icon://delete" type="Reject" press="onDelete"></Button>
		</ColumnListItem>
		</items>
		</Table>
		</content>
		<footer>
			<Bar >
				<contentRight>
                <Button text="Submit" type="Accept" icon="sap-icon://save" press="onSave"></Button>		
                </contentRight>
			</Bar>
		</footer>
		<f:SimpleForm title="Upload profile pic" editable="true" layout="ResponsiveGridLayout" >
				<f:content>
				<Label text="Select your profile picture"></Label>
				<unified:FileUploader id="idfilepic" uploadUrl="/sap/opu/odata/sap/ZEMPDATA_SRV/resumeSet" 
				sendXHR="true" change="onSelectfile" uploadComplete="onUploadcomplete" ></unified:FileUploader >
                <Button text="Submit" type="Emphasized" width="120px" press="onPressupload"></Button>
				</f:content>
		</f:SimpleForm>
       <Panel headerText="Upload your CV's">
       <upload:UploadSet id="Iduploadcv" multiple="true" instantUpload="false"
	   uploadUrl="/sap/opu/odata/sap/ZEMPDATA_SRV/resumeSet" uploadCompleted="oncvuploadCompleted"  />
	   <Button text="UploadCV's" type="Emphasized" width="120px" press="oncvuploadsap"></Button>
	   </Panel>
	</Page>
</mvc:View>
