<mvc:View
	xmlns:richtexteditor="sap.fe.macros.richtexteditor"
	xmlns:core="sap.ui.core" controllerName="com.pjnamespace.project4.controller.View2"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	>
	<Page id="page1" title="I am Object page for Employee">
		<content>
			<ObjectHeader id="objhead" title="{Empname}" number="{Salary}" numberUnit="{Zcurrency}" >
				<attributes>
					<ObjectAttribute title="Empployee ID" text="{Empid}" />
					<ObjectAttribute title="Email" text="{Mailid}"></ObjectAttribute>
				</attributes>
				<statuses>
					<ObjectStatus text="{Status}"></ObjectStatus>
				</statuses>
			</ObjectHeader>
			<IconTabBar >
				<items>
					<IconTabFilter icon="sap-icon://information" >
						<f:SimpleForm id="SF" editable="false" >
							<f:content>
								<Label text="Emp Id"></Label>
								<Text text="{Empid}" id="1" ></Text>
								<Label text="Emp Name"></Label>
								<Text text="{Empname}" id="2"></Text>
								<Label text="City"></Label>
								<Text text="{City}" id="3"></Text>
								<Label text="Begin Date"></Label>
								<Text text="{path:'Begindate',formatter:'.f.formatDate'}"/>		
								<Label text="Country"></Label>
								<Text text="{Country}"/>			
								<Label text="Salary"></Label>
								<Text text="{Salary}" id="6"></Text>
								<Label text="Currency"></Label>
								<Text text="{Zcurrency}" id="7"></Text>
								<Label text="Phone"></Label>
								<Text text="{Phonenumber}" id="8"></Text>
								<Label text="Email"></Label>
								<Text text="{Mailid}" id="9"></Text>
							</f:content>
						</f:SimpleForm>
					</IconTabFilter>
				</items>
			</IconTabBar>
		</content>
	</Page>
</mvc:View>